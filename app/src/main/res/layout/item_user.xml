<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/defapp"
        android:orientation="vertical"
        android:padding="12dp">

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TableRow>
                <TextView
                    android:layout_weight="1"
                    android:text="ID:"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_item_user_id"
                    android:layout_weight="2"
                    android:textColor="#333333"
                    tools:text="123456789" />
            </TableRow>

            <TableRow>
                <TextView
                    android:layout_weight="1"
                    android:text="First Name:"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_item_user_fname"
                    android:layout_weight="2"
                    android:textColor="#333333"
                    tools:text="John" />
            </TableRow>

            <TableRow>
                <TextView
                    android:layout_weight="1"
                    android:text="Last Name:"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_item_user_lname"
                    android:layout_weight="2"
                    android:textColor="#333333"
                    tools:text="Doe" />
            </TableRow>

            <TableRow>
                <TextView
                    android:layout_weight="1"
                    android:text="Email:"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_item_user_email"
                    android:layout_weight="2"
                    android:textColor="#333333"
                    tools:text="john.doe@example.com" />
            </TableRow>

            <TableRow>
                <TextView
                    android:layout_weight="1"
                    android:text="Password:"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_item_user_password"
                    android:layout_weight="2"
                    android:textColor="#333333"
                    tools:text="********" />
            </TableRow>

        </TableLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_update_user"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="@color/defbutton"
                android:padding="2dp"
                android:text="Edit"
                android:textAllCaps="false"
                android:textSize="12sp"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/btn_make_admin"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1.2"
                android:backgroundTint="@color/specbutton"
                android:padding="2dp"
                android:text="Make Admin"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/btn_delete_user"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="#D32F2F"
                android:padding="2dp"
                android:text="Delete"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/defapp"
    tools:context=".screens.MainActivity">

    <!-- App Banner (no crop / no stretch) -->
    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/app_banner"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- User Name -->
    <TextView
        android:id="@+id/NameView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/imageView2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Logout -->
    <Button
        android:id="@+id/btn_main_logout"
        android:layout_width="140dp"
        android:layout_height="48dp"
        android:text="Logout"
        android:backgroundTint="@color/defbutton"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/NameView"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Update Info -->
    <Button
        android:id="@+id/btn_from_main_to_update"
        android:layout_width="140dp"
        android:layout_height="48dp"
        android:text="Update Info"
        android:backgroundTint="@color/defbutton"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/NameView"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Main Menu -->
    <LinearLayout
        android:id="@+id/menuContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/btn_main_logout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_tender_red"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:text="View Tenders"
            android:backgroundTint="@color/specbutton"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_view_applications"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:text="View Applications"
            android:backgroundTint="@color/specbutton"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_general_terms_red"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:text="General Terms"
            android:backgroundTint="@color/specbutton"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_admin_page"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:text="Admin Page"
            android:backgroundTint="@color/specbutton"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_contact_red"
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:text="Contact"
            android:backgroundTint="@color/specbutton" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

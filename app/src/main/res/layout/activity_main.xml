<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E3F2FD"
    tools:context=".screens.MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:adjustViewBounds="true"
                android:padding="16dp"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/app_banner" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:id="@+id/header_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/user_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/profileImage"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:src="@drawable/image" />
                            <Button
                                android:id="@+id/NameView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:backgroundTint="@android:color/transparent"
                                android:text="Welcome"
                                android:textColor="#0D47A1"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-black"
                                app:icon="@drawable/view_profile_logo"
                                app:iconTint="#0D47A1" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <Button
                                android:id="@+id/btn_main_logout"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:backgroundTint="#FFEBEE"
                                android:text="LOGOUT"
                                android:textColor="#D32F2F"
                                app:icon="@drawable/logout_button_logo"
                                app:iconTint="#D32F2F"
                                app:cornerRadius="12dp" />
                            <Button
                                android:id="@+id/btn_from_main_to_update"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:backgroundTint="#E3F2FD"
                                android:text="UPDATE INFO"
                                android:textColor="#1976D2"
                                app:icon="@drawable/update_info_logo"
                                app:iconTint="#1976D2"
                                app:cornerRadius="12dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/guest_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:visibility="gone"> <Button
                        android:id="@+id/btn_main_login_page"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#1976D2"
                        android:text="LOGIN"
                        app:icon="@drawable/login_button_logo"
                        app:cornerRadius="12dp" />

                        <Button
                            android:id="@+id/btn_main_register_page"
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:backgroundTint="@android:color/white"
                            android:text="REGISTER"
                            android:textColor="#1976D2"
                            app:strokeColor="#1976D2"
                            app:strokeWidth="2dp"
                            app:icon="@drawable/register_button_logo"
                            app:iconTint="#1976D2"
                            app:cornerRadius="12dp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/menuContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="20dp">

                <Button
                    android:id="@+id/btn_tender_red"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#1976D2"
                    android:text="VIEW TENDERS"
                    app:icon="@drawable/tender_list_logo"
                    app:cornerRadius="20dp" />

                <Button
                    android:id="@+id/btn_view_applications"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#1976D2"
                    android:text="VIEW APPLICATIONS"
                    app:icon="@drawable/view_application_logo"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btn_view_app_status"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#1976D2"
                    android:text="VIEW APPLICATIONS STATUS"
                    app:icon="@drawable/view_application_logo"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/btn_admin_page"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#0D47A1"
                    android:text="ADMIN PAGE"
                    app:icon="@drawable/admin_page_logo"
                    app:cornerRadius="20dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                app:srcCompat="@drawable/image_main" />

            <LinearLayout
                android:id="@+id/footer_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingBottom="32dp">

                <View
                    android:layout_width="100dp"
                    android:layout_height="1dp"
                    android:layout_marginBottom="16dp"
                    android:background="#BBDEFB" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_general_terms_red"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GENERAL TERMS"
                    android:textColor="#546E7A"
                    android:textSize="12sp"
                    app:icon="@drawable/general_terms_logo"
                    app:iconSize="18dp"
                    app:iconTint="#546E7A" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_contact_red"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTACT US"
                    android:textColor="#546E7A"
                    android:textSize="12sp"
                    app:icon="@drawable/contact_us_logo"
                    app:iconSize="18dp"
                    app:iconTint="#546E7A" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_about_red"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    android:textColor="#546E7A"
                    android:textSize="12sp"
                    app:icon="@drawable/about_logo"
                    app:iconSize="18dp"
                    app:iconTint="#546E7A" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
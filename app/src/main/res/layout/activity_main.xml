<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background"
    tools:context=".screens.MainActivity">

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:maxHeight="180dp"
        android:padding="16dp"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/app_banner" />

    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/imageView2">

        <TextView
            android:id="@+id/NameView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif-black"
            android:text="Welcome"
            android:textColor="@color/black"
            android:textSize="24sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:id="@+id/user_layout"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_main_logout"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/defbutton"
                android:text="Logout"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/btn_from_main_to_update"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/defbutton"
                android:text="Update Info"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="8dp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:id="@+id/guest_layout"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_main_login_page"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/defbutton"
                android:text="Login"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/btn_main_register_page"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/defbutton"
                android:text="Register"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/footer_container"
        app:layout_constraintTop_toBottomOf="@id/header_layout">

        <LinearLayout
            android:id="@+id/menuContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp">

            <Button
                android:id="@+id/btn_tender_red"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/specbutton"
                android:text="View Tenders"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btn_view_applications"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/specbutton"
                android:text="View Applications"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btn_admin_page"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/specbutton"
                android:text="Admin Page"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/footer_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_general_terms_red"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="@color/defbutton"
            android:paddingHorizontal="24dp"
            android:text="General Terms"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:cornerRadius="20dp" />

        <Button
            android:id="@+id/btn_contact_red"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="@color/defbutton"
            android:paddingHorizontal="24dp"
            android:text="Contact Us"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:cornerRadius="20dp" />

        <Button
            android:id="@+id/btn_about_red"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="@color/defbutton"
            android:paddingHorizontal="24dp"
            android:text="About"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            app:cornerRadius="20dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
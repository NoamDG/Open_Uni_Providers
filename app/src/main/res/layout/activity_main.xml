<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/defapp"
    tools:context=".screens.MainActivity">

    <Button
        android:id="@+id/btn_main_logout"
        android:layout_width="151dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:backgroundTint="@color/defbutton"
        android:text="LOGOUT"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.149" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/app_banner" />

    <Button
        android:id="@+id/btn_tender_red"
        android:layout_width="202dp"
        android:layout_height="48dp"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="15dp"
        android:text="View Tenders"
        android:backgroundTint="@color/specbutton"
        app:layout_constraintBottom_toTopOf="@+id/btn_exempt_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_main_logout" />

    <Button
        android:id="@+id/btn_exempt_red"
        android:layout_width="205dp"
        android:layout_height="48dp"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="15dp"
        android:text="Tenders Exemptions"
        android:backgroundTint="@color/specbutton"
        app:layout_constraintBottom_toTopOf="@+id/btn_bidder_list_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.49"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_tender_red" />

    <Button
        android:id="@+id/btn_bidder_list_red"
        android:layout_width="202dp"
        android:layout_height="48dp"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="15dp"
        android:text="General Terms"
        android:backgroundTint="@color/specbutton"
        app:layout_constraintBottom_toTopOf="@+id/btn_general_terms_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.502"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_exempt_red" />

    <Button
        android:id="@+id/btn_general_terms_red"
        android:layout_width="203dp"
        android:layout_height="48dp"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="112dp"
        android:text="List of Bidders"
        android:backgroundTint="@color/specbutton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_bidder_list_red" />

    <Button
        android:id="@+id/btn_contact_red"
        android:layout_width="203dp"
        android:layout_height="48dp"
        android:text="Contact"
        android:backgroundTint="@color/specbutton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.485"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.944" />

    <TextView
        android:id="@+id/NameView"
        android:layout_width="213dp"
        android:layout_height="42dp"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="71dp"
        android:gravity="center"
        android:text="TextView"
        android:textColor="@color/black"
        android:textSize="90px"
        app:layout_constraintBottom_toTopOf="@+id/btn_tender_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView2"
        app:layout_constraintVertical_bias="0.0" />


</androidx.constraintlayout.widget.ConstraintLayout>
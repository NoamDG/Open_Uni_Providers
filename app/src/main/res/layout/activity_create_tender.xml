<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/defapp"
    tools:context=".screens.CreateTenderActivity">

    <!-- Title -->
    <TextView
        android:id="@+id/titleCreateTender"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Create Tender"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tender Subject -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutTenderSubject"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Tender Subject"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="#3F51B5"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/titleCreateTender"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/TenderSubject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:padding="16dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Publish Date -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutPubDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Publish Date"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="#3F51B5"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTenderSubject"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/PubDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:padding="16dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Expire Date -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutExpDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Expire Date"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="#3F51B5"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutPubDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/ExpDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:padding="16dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Status -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Status"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="#3F51B5"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutExpDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/Status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:padding="16dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Winner Name -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutWinnerName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Winner Name"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="#3F51B5"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/WinnerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:padding="16dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Content Button -->
    <Button
        android:id="@+id/btnContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Content of Tender"
        android:textAllCaps="false"
        android:backgroundTint="@color/defbutton"
        android:textColor="@android:color/white"
        android:paddingVertical="14dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutWinnerName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cornerRadius="16dp"/>

    <!-- Submit Button -->
    <Button
        android:id="@+id/btn_submit_create_tender"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Submit"
        android:textAllCaps="false"
        android:backgroundTint="@color/specbutton"
        android:textColor="@android:color/white"
        android:paddingVertical="14dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnContent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cornerRadius="16dp"/>

    <!-- Back Button -->
    <Button
        android:id="@+id/btn_back_in_create_tender"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Back"
        android:textAllCaps="false"
        android:backgroundTint="@color/defbutton"
        android:textColor="@android:color/white"
        android:paddingVertical="14dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btn_submit_create_tender"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:cornerRadius="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
